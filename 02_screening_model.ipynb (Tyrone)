        "import requests\n",
        "import pandas as pd\n",
        "import time\n",
        "\n",
        "def get_all_crbn_binders(target_id='CHEMBL3763008'):\n",
        "    \"\"\"\n",
        "    Fetches ALL unique molecules (binders) tested against a specific ChEMBL target ID\n",
        "    by paging through all available activity records.\n",
        "    \"\"\"\n",
        "    url = \"https://www.ebi.ac.uk/chembl/api/data/activity\"\n",
        "    unique_molecules = []\n",
        "    seen_ids = set()\n",
        "    limit = 1000\n",
        "    offset = 0\n",
        "\n",
        "    print(f\"Starting data retrieval for target {target_id}...\")\n",
        "\n",
        "    while True:\n",
        "        params = {\n",
        "            'target_chembl_id': target_id,\n",
        "            'format': 'json',\n",
        "            'limit': limit,\n",
        "            'offset': offset\n",
        "        }\n",
        "\n",
        "        response = requests.get(url, params=params)\n",
        "        response.raise_for_status()\n",
        "        data = response.json()\n",
        "\n",
        "        activities = data.get('activities', [])\n",
        "        if not activities:\n",
        "            break\n",
        "\n",
        "        for act in activities:\n",
        "            mol_id = act.get('molecule_chembl_id')\n",
        "            if mol_id and mol_id not in seen_ids:\n",
        "                unique_molecules.append({\n",
        "                    'molecule_chembl_id': mol_id,\n",
        "                    'smiles': act.get('canonical_smiles'),\n",
        "                    'standard_type': act.get('standard_type'),\n",
        "                    'standard_value': act.get('standard_value'),\n",
        "                    'standard_units': act.get('standard_units')\n",
        "                })\n",
        "                seen_ids.add(mol_id)\n",
        "\n",
        "        total_count = data['page_meta']['total_count']\n",
        "        offset += limit\n",
        "        print(f\"Progress: {min(offset, total_count)}/{total_count} records processed...\")\n",
        "\n",
        "        if offset >= total_count:\n",
        "            break\n",
        "\n",
        "    return pd.DataFrame(unique_molecules)\n",
        "\n",
        "# Execute full retrieval\n",
        "df_all_binders = get_all_crbn_binders()\n",
        "\n",
        "print(f\"\\nSuccessfully found {len(df_all_binders)} unique binders.\")\n",
        "display(df_all_binders.head())"
