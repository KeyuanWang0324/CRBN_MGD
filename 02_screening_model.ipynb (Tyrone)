        "#Ryan\n",
        "from rdkit import Chem\n",
        "from rdkit.Chem import Descriptors, AllChem\n",
        "import numpy as np\n",
        "\n",
        "def process_smiles(smiles: str, n_bits: int = 2048, radius: int = 2):\n",
        "    \"\"\"\n",
        "    1. Convert SMILES -> RDKit molecule\n",
        "    2. Compute molecular weight and attach it as a property\n",
        "    3. Generate a 2048-bit Morgan (ECFP) fingerprint\n",
        "\n",
        "    Returns: (mol, molecular_weight, fingerprint_array)\n",
        "    \"\"\"\n",
        "    # Step 1: SMILES -> molecule\n",
        "    mol = Chem.MolFromSmiles(smiles)\n",
        "    if mol is None:\n",
        "        raise ValueError(f\"Invalid SMILES string: {smiles}\")\n",
        "\n",
        "    # Step 2: compute molecular weight and store it on the molecule\n",
        "    mol_weight = Descriptors.MolWt(mol)\n",
        "    mol.SetDoubleProp(\"molecular_weight\", mol_weight)\n",
        "\n",
        "    # Step 3: molecule -> 2048-bit fingerprint\n",
        "    fp = AllChem.GetMorganFingerprintAsBitVect(mol, radius=radius, nBits=n_bits)\n",
        "    fp_array = np.zeros((n_bits,), dtype=int)\n",
        "    Chem.DataStructs.ConvertToNumpyArray(fp, fp_array)\n",
        "\n",
        "    return mol, mol_weight, fp_array\n",
        "\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    smiles_input = input(\"Enter a SMILES string: \").strip()\n",
        "\n",
        "    mol, mol_weight, fingerprint = process_smiles(smiles_input)\n",
        "\n",
        "    print(f\"\\nMolecule: {Chem.MolToSmiles(mol)}\")\n",
        "    print(f\"Molecular weight: {mol_weight:.2f} g/mol\")\n",
        "    print(f\"Fingerprint length: {len(fingerprint)}\")\n",
        "    print(f\"Fingerprint (first 50 bits): {fingerprint[:50]}\")\n",
        "    print(f\"Number of bits set to 1: {fingerprint.sum()}\")"
      ],
