        "#Ryan\n",
        "import requests\n",
        "\n",
        "CHEMBL_BASE_URL = \"https://www.ebi.ac.uk/chembl/api/data\"\n",
        "\n",
        "\n",
        "def get_crbn_target_id():\n",
        "    url = f\"{CHEMBL_BASE_URL}/target/search\"\n",
        "    params = {\"q\": \"CRBN\", \"format\": \"json\"}\n",
        "    resp = requests.get(url, params=params)\n",
        "    resp.raise_for_status()\n",
        "    data = resp.json()\n",
        "\n",
        "    targets = data.get(\"targets\", [])\n",
        "    if not targets:\n",
        "        raise ValueError(\"No CRBN target found in ChEMBL\")\n",
        "\n",
        "    for t in targets:\n",
        "        if t.get(\"target_type\") == \"SINGLE PROTEIN\" and t.get(\"organism\") == \"Homo sapiens\":\n",
        "            return t[\"target_chembl_id\"], t[\"pref_name\"]\n",
        "\n",
        "    return targets[0][\"target_chembl_id\"], targets[0][\"pref_name\"]\n",
        "\n",
        "\n",
        "def count_total_activity_records(target_chembl_id):\n",
        "    \"\"\"\n",
        "    Quick count: total number of bioactivity records (not unique compounds)\n",
        "    tested against this target. ChEMBL returns this in page_meta without\n",
        "    needing to fetch every record.\n",
        "    \"\"\"\n",
        "    url = f\"{CHEMBL_BASE_URL}/activity\"\n",
        "    params = {\n",
        "        \"target_chembl_id\": target_chembl_id,\n",
        "        \"format\": \"json\",\n",
        "        \"limit\": 1,  # we only need the count metadata, not the data\n",
        "    }\n",
        "    resp = requests.get(url, params=params)\n",
        "    resp.raise_for_status()\n",
        "    data = resp.json()\n",
        "    return data[\"page_meta\"][\"total_count\"]\n",
        "\n",
        "\n",
        "def count_unique_binders(target_chembl_id, batch_size=1000):\n",
        "    \"\"\"\n",
        "    Total number of UNIQUE compounds ('binders') with a bioactivity record\n",
        "    against this target. Pages through all activity records and dedupes\n",
        "    by molecule_chembl_id.\n",
        "    \"\"\"\n",
        "    url = f\"{CHEMBL_BASE_URL}/activity\"\n",
        "    unique_molecules = set()\n",
        "    offset = 0\n",
        "\n",
        "    while True:\n",
        "        params = {\n",
        "            \"target_chembl_id\": target_chembl_id,\n",
        "            \"molecule_chembl_id__isnull\": \"false\",\n",
        "            \"format\": \"json\",\n",
        "            \"limit\": batch_size,\n",
        "            \"offset\": offset,\n",
        "        }\n",
        "        resp = requests.get(url, params=params)\n",
        "        resp.raise_for_status()\n",
        "        data = resp.json()\n",
        "\n",
        "        activities = data.get(\"activities\", [])\n",
        "        if not activities:\n",
        "            break\n",
        "\n",
        "        for record in activities:\n",
        "            chembl_id = record.get(\"molecule_chembl_id\")\n",
        "            if chembl_id:\n",
        "                unique_molecules.add(chembl_id)\n",
        "\n",
        "        total = data[\"page_meta\"][\"total_count\"]\n",
        "        offset += batch_size\n",
        "        if offset >= total:\n",
        "            break\n",
        "\n",
        "    return len(unique_molecules)\n",
        "\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    target_id, target_name = get_crbn_target_id()\n",
        "    print(f\"Target: {target_name} ({target_id})\\n\")\n",
        "\n",
        "    total_records = count_total_activity_records(target_id)\n",
        "    print(f\"Total bioactivity records against CRBN: {total_records}\")\n",
        "\n",
        "    total_binders = count_unique_binders(target_id)\n",
        "    print(f\"Total unique compounds ('binders') tested against CRBN: {total_binders}\")"
